package-as: QuickWoWTalents

enable-nolib-creation: no

manual-changelog:
  filename: CURSEFORGE_CHANGELOG.md
  markup-type: plain

license-output: LICENSE.txt

ignore:
  - .github
  - CHANGELOG.md
  - docs
  - scripts
  - test
  - dist
  - node_modules
  - package.json
  - package-lock.json
  - README.md
  - RELEASING.md
